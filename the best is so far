type LogLevel = "DEBUG" | "INFO" | "WARN" | "ERROR";

export const logger = {
  _fmt: (lvl: LogLevel, msg: string, m?: Record<string, unknown>) =>
    JSON.stringify({ ts: new Date().toISOString(), level: lvl, msg, ...m }),
  debug: (msg: string, m?: Record<string, unknown>) => console.debug(logger._fmt("DEBUG", msg, m)),
  info:  (msg: string, m?: Record<string, unknown>) => console.log(logger._fmt("INFO",  msg, m)),
  warn:  (msg: string, m?: Record<string, unknown>) => console.warn(logger._fmt("WARN",  msg, m)),
  error: (msg: string, m?: Record<string, unknown>) => console.error(logger._fmt("ERROR", msg, m)),
};

// ═══════════════════════════════════════════════════════════════
//  RETRY
// ═══════════════════════════════════════════════════════════════

export async function withRetry<T>(fn: () => Promise<T>, retries = 3, delayMs = 500): Promise<T> {
  let last: unknown;
  for (let i = 0; i < retries; i++) {
    try { return await fn(); }
    catch (e) {
      last = e;
      if (i < retries - 1) await new Promise(r => setTimeout(r, delayMs * (i + 1)));
    }
  }
  throw last;
}

